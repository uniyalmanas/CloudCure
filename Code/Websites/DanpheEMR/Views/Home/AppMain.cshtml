@using System;
@using System.Collections.Generic;
@using System.Linq;
@using System.Text;
@using DanpheEMR.Security;

@{
    List<DanpheRoute> validRoutes = (List<DanpheRoute>)ViewData["validroutes"];
    RbacUser currUser = (RbacUser)ViewData["currentuser"];
    validRoutes = validRoutes.Where(r => r.DefaultShow != false && r.IsActive == true).ToList();
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;600;700;800;900&family=Oswald:wght@500;700&display=swap');

    body, .page-content, h1, h2, h3, h4, h5, h6, input, select, textarea, button, span, a, div {
        font-family: 'Outfit', 'Inter', -apple-system, BlinkMacSystemFont, sans-serif !important;
    }

    .nav-schedule {
        background-image: url('/themes/theme-default/images/nav/schedule.PNG');
    }

    .help-about {
        color: #fdefef !important;
        font-size: 19px !important;
    }

    .page-sidebar .page-sidebar-menu ul.sub-menu {
        margin: 0px;
    }

    span.ad-sign:after {
        position: absolute;
        display: inline-block;
        content: '\2013';
        right: 5px;
        top: 11px;
        text-align: center;
        background: #0d9488 !important;
        border-radius: 50% !important;
        z-index: 22;
        width: 24px;
        height: 24px;
        line-height: 20px;
        font-weight: bold;
        color: #fff;
        font-size: 20px;
        transition: transform .25s linear;
        -webkit-transition: -webkit-transform .25s linear;
    }

    span.ad-sign.collapsed:after {
        line-height: 24px !important;
        content: '+';
        -webkit-transform: rotate(90deg);
        transform: rotate(90deg);
    }

    span.ad-sign:after {
        -webkit-transform: rotate(180deg);
        transform: rotate(180deg);
    }

    .page-sidebar-menu-closed span.ad-sign {
        display: none;
    }

    ul.page-sidebar-menu > li {
        position: relative;
    }

    /* Premium Theme Overrides */
    .page-header.navbar {
        background: linear-gradient(135deg, #10b981, #0d9488) !important;
        box-shadow: 0 4px 20px rgba(13, 148, 136, 0.15) !important;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1) !important;
        height: 60px !important;
    }

    .page-header.navbar .page-logo {
        background: transparent !important;
        width: 235px !important;
        height: 60px !important;
        display: flex !important;
        align-items: center !important;
        justify-content: space-between !important;
        padding: 0 20px !important;
        border-right: 1px solid rgba(255, 255, 255, 0.08) !important;
    }

    .page-header.navbar .menu-toggler.sidebar-toggler {
        float: none !important;
        margin: 0 !important;
        opacity: 0.85;
        transition: all 0.2s ease;
    }
    .page-header.navbar .menu-toggler.sidebar-toggler:hover {
        opacity: 1;
        transform: scale(1.05);
    }

    .page-header.navbar .top-menu .navbar-nav > li.dropdown-user > a {
        padding: 8px 12px !important;
        border-radius: 8px !important;
        background: rgba(255, 255, 255, 0.08) !important;
        margin-top: 10px !important;
        border: 1px solid rgba(255, 255, 255, 0.12) !important;
        transition: all 0.2s ease;
    }
    .page-header.navbar .top-menu .navbar-nav > li.dropdown-user > a:hover {
        background: rgba(255, 255, 255, 0.15) !important;
        border-color: rgba(255, 255, 255, 0.2) !important;
    }

    .page-sidebar-wrapper, .page-sidebar {
        background-color: #071917 !important;
        box-shadow: 4px 0 25px rgba(0, 0, 0, 0.15) !important;
        border-right: 1px solid rgba(13, 148, 136, 0.1) !important;
    }

    .page-sidebar .page-sidebar-menu {
        background-color: #071917 !important;
        padding-top: 15px !important;
    }

    ul.page-sidebar-menu > li {
        margin: 4px 10px !important;
        border-radius: 10px !important;
        overflow: hidden !important;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
    }

    ul.page-sidebar-menu > li > a {
        background: transparent !important;
        border-top: none !important;
        border-left: 4px solid transparent !important;
        color: #9cc2be !important;
        padding: 12px 16px !important;
        border-radius: 10px !important;
        font-weight: 500 !important;
        transition: all 0.25s ease !important;
    }

    ul.page-sidebar-menu > li > a:hover, 
    ul.page-sidebar-menu > li.open > a {
        background: rgba(13, 148, 136, 0.08) !important;
        color: #14b8a6 !important;
        border-left-color: #0d9488 !important;
    }

    ul.page-sidebar-menu > li > a.left-nav-active {
        background: linear-gradient(90deg, rgba(13, 148, 136, 0.15), transparent) !important;
        color: #0d9488 !important;
        font-weight: 700 !important;
        border-left: 4px solid #0d9488 !important;
        box-shadow: inset 2px 0 8px rgba(13, 148, 136, 0.04) !important;
    }

    .page-sidebar .page-sidebar-menu ul.sub-menu {
        background-color: #051312 !important;
        padding: 6px 0 !important;
    }

    .page-sidebar .page-sidebar-menu ul.sub-menu > li > a {
        color: #8dafa8 !important;
        font-size: 13px !important;
        padding: 8px 15px 8px 30px !important;
        font-weight: 500 !important;
        transition: all 0.2s ease !important;
    }

    .page-sidebar .page-sidebar-menu ul.sub-menu > li > a:hover,
    .page-sidebar .page-sidebar-menu ul.sub-menu > li > a.left-nav-active {
        color: #14b8a6 !important;
        background: transparent !important;
    }

    .page-content-bg-solid, .cstm-pg-content, .page-content {
        background-color: #f6f9f8 !important;
    }

    .portlet, .portlet.box, .panel, .modelbox-div {
        border-radius: 16px !important;
        overflow: hidden !important;
        box-shadow: 0 20px 40px -15px rgba(13, 148, 136, 0.05), 0 1px 3px rgba(0, 0, 0, 0.02) !important;
        border: 1px solid rgba(226, 232, 240, 0.8) !important;
        background-color: #ffffff !important;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
    }

    .portlet:hover, .portlet.box:hover, .panel:hover, .modelbox-div:hover {
        box-shadow: 0 30px 60px -20px rgba(13, 148, 136, 0.12), 0 1px 4px rgba(0, 0, 0, 0.03) !important;
        transform: translateY(-2px) !important;
    }

    .portlet.box.blue-hoki, .portlet.box.blue, .portlet.box.green, .portlet.box.red {
        background-color: #fff !important;
        border: 1px solid rgba(226, 232, 240, 0.8) !important;
    }

    .portlet.box > .portlet-title {
        background: #ffffff !important;
        border-bottom: 1px solid #f1f5f9 !important;
        color: #0f172a !important;
        padding: 16px 20px !important;
        border-left: 4px solid #0d9488 !important;
        min-height: auto !important;
    }

    .portlet.box > .portlet-title .caption {
        font-family: 'Oswald', sans-serif !important;
        color: #0f172a !important;
        font-weight: 700 !important;
        font-size: 15px !important;
        letter-spacing: 0.5px !important;
        text-transform: uppercase !important;
    }

    .portlet.box > .portlet-body {
        padding: 24px !important;
        background-color: #fff !important;
    }

    .sub-navtab, .nav-tabs {
        border-bottom: 2px solid rgba(13, 148, 136, 0.1) !important;
        margin-bottom: 20px !important;
    }

    .nav-tabs > li > a {
        font-weight: 600 !important;
        color: #4b5563 !important;
        padding: 10px 18px !important;
        border: none !important;
        background: transparent !important;
        border-bottom: 3px solid transparent !important;
        transition: all 0.3s ease !important;
    }

    .nav-tabs > li > a:hover {
        color: #0d9488 !important;
        border-bottom-color: rgba(13, 148, 136, 0.3) !important;
    }

    .nav-tabs > li.active > a, .nav-tabs > li > a.a-tab-active {
        color: #0d9488 !important;
        font-weight: 750 !important;
        border: none !important;
        border-bottom: 3px solid #0d9488 !important;
        background: transparent !important;
    }

    .form-control {
        background-color: #ffffff !important;
        border: 1.5px solid #d1d5db !important;
        height: 40px !important;
        border-radius: 8px !important;
        padding: 6px 12px !important;
        font-size: 13.5px !important;
        font-weight: 500 !important;
        color: #1f2937 !important;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1) !important;
        box-shadow: none !important;
    }

    .form-control:focus {
        border-color: #0d9488 !important;
        background-color: #ffffff !important;
        box-shadow: 0 0 0 4px rgba(13, 148, 136, 0.1) !important;
    }

    .btn, .btn.blue, .btn.green, .btn-primary, .btn-success {
        border-radius: 8px !important;
        font-weight: 600 !important;
        padding: 8px 16px !important;
        font-size: 13.5px !important;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1) !important;
        border: none !important;
    }

    .btn.green, .btn.blue, .btn.btn-success, .btn-primary, #regPatientSubmitBtn, #editPatientRecordSubmitBtn {
        background: linear-gradient(135deg, #10b981, #0d9488) !important;
        color: #fff !important;
        box-shadow: 0 10px 22px -5px rgba(13, 148, 136, 0.35) !important;
    }

    .btn.green:hover, .btn.blue:hover, .btn.btn-success:hover, .btn-primary:hover, #regPatientSubmitBtn:not([disabled]):hover, #editPatientRecordSubmitBtn:not([disabled]):hover {
        background: linear-gradient(135deg, #0d9488, #0b7a70) !important;
        transform: translateY(-2px) !important;
        box-shadow: 0 15px 30px -5px rgba(13, 148, 136, 0.45) !important;
        opacity: 0.98;
    }

    .btn-default, .btn.btn-default {
        background-color: #f3f4f6 !important;
        color: #4b5563 !important;
        border: 1px solid #e5e7eb !important;
    }

    .btn-default:hover {
        background-color: #e5e7eb !important;
        color: #1f2937 !important;
    }
</style>

<body class="page-header-fixed page-sidebar-closed-hide-logo page-content-white">
    <div class="page-wrapper">
        <!-- BEGIN HEADER -->
        <div *ngIf="navService.showTopNav" class="page-header navbar navbar-fixed-top">
            <!-- BEGIN HEADER INNER -->
            <div class="page-header-inner ">
                <!-- BEGIN LOGO -->
                <div class="page-logo">
                    <a href="#">

                        <img src="~/themes/theme-default/images/hospitals-logo/hospital-logo-landingpage.png" alt="logo" class="logo-default" style="width:155px;height:36px;margin-top:8px" title="Go to DanpheEMR-Home" />
                    </a>
                    <div class="menu-toggler sidebar-toggler">
                        <span></span>
                    </div>
                </div>
                <div style="display: inline-block;color:#f3e2e2;padding-left: 66px;font-size: 16px;">
                    <b>
                        {{PatService.globalPatient.ShortName}}&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                        <span *ngIf="PatService.globalPatient.PatientCode != null">
                            Hospital No : {{PatService.globalPatient.PatientCode}}
                        </span>
                        &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                    </b>

                    <b>
                        <span *ngIf="PatService.globalPatient.DateOfBirth != null">
                            Age/Sex :  {{PatService.globalPatient.DateOfBirth | DanpheDateTime:'age' }}
                        </span>
                        <span *ngIf="PatService.globalPatient.DateOfBirth != null"> / {{PatService.globalPatient.Gender}} </span>
                    </b>
                    @*<span *ngIf="PatService.globalPatient.EMPI != null">{{pageParameters.EmpiLabel}}: <b>{{PatService.globalPatient.EMPI }}</b></span>*@

                    @*<span *ngIf="PatService.globalPatient.DateOfBirth != null">
                            DOB:-<b>{{PatService.globalPatient.DateOfBirth | DanpheDateTime:'format':'YYYY-MM-DD' }}</b>
                        </span>*@
                </div>
                <!-- END LOGO -->
                <!-- BEGIN RESPONSIVE MENU TOGGLER -->
                <a href="javascript:;" class="menu-toggler responsive-toggler" data-toggle="collapse" data-target=".navbar-collapse">
                    <span></span>
                </a>
                <!-- END RESPONSIVE MENU TOGGLER -->
                <!-- BEGIN TOP NAVIGATION MENU -->
                <div class="top-menu">

                    <ul class="nav navbar-nav pull-right">
                        <li title="My notifications">
                            <notification-icon>

                            </notification-icon>
                        </li>

                        <!-- BEGIN NOTIFICATION DROPDOWN -->
                        <!-- DOC: Apply "dropdown-dark" class after "dropdown-extended" to change the dropdown styte -->
                        <!-- DOC: Apply "dropdown-hoverable" class after below "dropdown" and remove data-toggle="dropdown" data-hover="dropdown" data-close-others="true" attributes to enable hover dropdown mode -->
                        <!-- DOC: Remove "dropdown-hoverable" and add data-toggle="dropdown" data-hover="dropdown" data-close-others="true" attributes to the below A element with dropdown-toggle class -->
                        <!-- END NOTIFICATION DROPDOWN -->
                        <!-- BEGIN USER LOGIN DROPDOWN -->
                        <!-- DOC: Apply "dropdown-dark" class after below "dropdown-extended" to change the dropdown styte -->
                        <li class="dropdown dropdown-user">
                            <a href="javascript:;" class="dropdown-toggle" data-toggle="dropdown" data-hover="dropdown" data-close-others="true">
                                <img alt="" class="img-circle" *ngIf="currentUsr.Profile.ImageLocation!=''" src="{{currentUsr.Profile.ImageLocation}}" />
                                <span class="username username-hide-on-mobile" style="color: white; font-weight: bold;"> @currUser.UserName </span>
                                <i class="fa fa-angle-down"></i>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-default">
                                <li>
                                    <a routerLink="Employee/ProfileMain">
                                        <i class="icon-user"></i> My Profile
                                    </a>
                                </li>

                                <li>
                                    <a href="@Url.Action("Logout","Account")" type="submit">
                                        <i class="icon-key"></i> Log Out
                                    </a>

                                </li>
                            </ul>
                        </li>
                        <!-- END USER LOGIN DROPDOWN -->

                        <li class="dropdown tooltip">
                            @*sud:24Dec-to display application's current version information on tooltip*@
                            <span *ngIf="coreService.appVersionNum" class="tooltiptext ttptextdown" style="width: 150px;margin-left: -75px;text-align: left;">
                                <i class="fa fa-info"></i>
                                {{coreService.appVersionNum}}
                            </span>
                            <a href="javascript:;" class="dropdown-toggle" data-toggle="dropdown" data-hover="dropdown" data-close-others="true">
                                <i class="fa fa-question-circle help-about"></i>
                                <i class="fa fa-angle-down"></i>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-default">
                                <li>
                                    <a (click)="DownloadUserManual()">
                                        <i class="fa fa-download"></i>Download user manual
                                    </a>
                                </li>
                              

                            </ul>
                        </li>

                    </ul>
                </div>
                <!-- END TOP NAVIGATION MENU -->
            </div>
            <!-- END HEADER INNER -->
        </div>
        <!-- END HEADER -->
        <!-- BEGIN HEADER & CONTENT DIVIDER -->
        <div class="clearfix"> </div>
        <!-- END HEADER & CONTENT DIVIDER -->
        <!-- BEGIN CONTAINER -->
        <div [ngClass]="navService.showTopNav ? 'page-container':'' ">

            <!-- BEGIN SIDEBAR -->
            <div *ngIf="navService.showSideNav" class="page-sidebar-wrapper">
                <!-- BEGIN SIDEBAR -->
                <!-- DOC: Set data-auto-scroll="false" to disable the sidebar from auto scrolling/focusing -->
                <!-- DOC: Change data-auto-speed="200" to adjust the sub menu slide up/down speed -->
                <div class="page-sidebar navbar-collapse collapse">
                    <!-- BEGIN SIDEBAR MENU -->
                    <!-- DOC: Apply "page-sidebar-menu-light" class right after "page-sidebar-menu" to enable light sidebar menu style(without borders) -->
                    <!-- DOC: Apply "page-sidebar-menu-hover-submenu" class right after "page-sidebar-menu" to enable hoverable(hover vs accordion) sub menu mode -->
                    <!-- DOC: Apply "page-sidebar-menu-closed" class right after "page-sidebar-menu" to collapse("page-sidebar-closed" class must be applied to the body element) the sidebar sub menu mode -->
                    <!-- DOC: Set data-auto-scroll="false" to disable the sidebar from auto scrolling/focusing -->
                    <!-- DOC: Set data-keep-expand="true" to keep the submenues expanded -->
                    <!-- DOC: Set data-auto-speed="200" to adjust the sub menu slide up/down speed -->
                    <ul class="menu-content out page-sidebar-menu" style="padding-top: 0px">
                        <!-- DOC: To remove the sidebar toggler from the sidebar you just need to completely remove the below "sidebar-toggler-wrapper" LI element -->
                        <!-- BEGIN SIDEBAR TOGGLER BUTTON -->
                        @*
                            <li class="sidebar-toggler-wrapper hide">
                                <div class="sidebar-toggler">
                                    <span></span>
                                </div>
                            </li>*@

                        <!-- END SIDEBAR TOGGLER BUTTON -->
                        @foreach (var route in validRoutes)
                        {

                            <li>
                                <a [routerLink]="'@route.UrlFullPath'" class="nav-link nav-toggle" [routerLinkActive]="'left-nav-active'">
                                    <img src="/themes/theme-default/images/nav/@route.Css" style="height: 25px;width: 30px;" />
                                    <span class="title"><b>@route.DisplayName</b></span>
                                    <span class="selected"></span>
                                    @*<span class="arrow open"></span>*@
                                </a>



                                @*show plus button only when there are child routes to be displayed*@

                                @if (route.ChildRoutes != null && route.ChildRoutes.Where(r => r.DefaultShow == true).Count() > 0)
                                {<span data-toggle="collapse" data-target="#@route.DisplayName.Replace(" ","")" class="collapsed ad-sign"></span>
                                    <ul class="sub-menu collapse" id="@route.DisplayName.Replace(" ","")">
                                        @foreach (var childroute in route.ChildRoutes)
                                        {
                                            @if (childroute != null && !string.IsNullOrEmpty(childroute.DisplayName) && childroute.DefaultShow != false)
                                            {
                                                <li class="nav-item">
                                                    <a [routerLink]="'@childroute.UrlFullPath'" class="nav-link" [routerLinkActive]="'left-nav-active'">
                                                        <i class="icon-bulb"></i>
                                                        <span class="title">@childroute.DisplayName</span>
                                                        <span class="badge badge-success"></span>
                                                    </a>
                                                </li>
                                            }
                                        }
                                    </ul>
                                }

                            </li>

                        }

                    </ul>

                    <!-- END SIDEBAR MENU -->
                    <!-- END SIDEBAR MENU -->
                </div>
                <!-- END SIDEBAR -->
            </div>
            <!-- END SIDEBAR -->
            <!-- BEGIN CONTENT -->
            <div class="page-content-wrapper">

                <!-- BEGIN CONTENT BODY -->
                <danphe-loading [loading]="loading"></danphe-loading>
                <danphe-msgbox></danphe-msgbox>
                <div [ngClass]="navService.showSideNav ? 'page-content':'cstm-pg-content' ">
                    <div class="row" style="margin-left:0px !important; margin-right:0px !important;">
                        <router-outlet (activate)="onActivate($event)"></router-outlet>
                    </div>
                    <!-- END CONTENT BODY -->
                </div>
            </div>
            <!-- END CONTENT -->

        </div>
        <!-- END CONTAINER -->
        <!-- BEGIN FOOTER -->
        <!-- END FOOTER -->
    </div>
</body>